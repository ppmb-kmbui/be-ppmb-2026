generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum NetworkingQuestionType {
  PEER
  SENIOR
}

model User {
  id                            Int                             @id @default(autoincrement())
  email                         String                          @unique
  fullname                      String?
  imgUrl                        String?                         @map("img_url")
  password                      String
  createdAt                     DateTime                        @default(now()) @map("created_at")
  updatedAt                     DateTime                        @default(now()) @updatedAt @map("updated_at")
  faculty                       String?
  isAdmin                       Boolean                         @default(false) @map("is_admin")
  batch                         Int                             @default(2026)
  lineId                        String?                         @map("line_id")
  whatsappNumber                String?                         @map("whatsapp_number")
  NetworkingSubmissions         NetworkingSubmission[]          @relation("NetworkingSubmissionOwner")
  NetworkingTargets             NetworkingSubmission[]          @relation("NetworkingSubmissionFriend")
  FossibSubmission              FossibSubmission?
  MentoringSubmission           MentoringSubmission?
  ConnectionRequestSender       ConnectionRequest[]             @relation("from")
  ConnectionRequestReciever     ConnectionRequest[]             @relation("to")
  ConnectionSender              Connection[]                    @relation("from")
  ConnectionReciever            Connection[]                    @relation("to")
  Quotes                        Quotes[]
  FirstFossibSessionSubmission  FirstFossibSessionSubmission[]
  SecondFossibSessionSubmission SecondFossibSessionSubmission[]
  InsightHuntingSubmission      InsightHuntingSubmission[]
  ExplorerSubmission            ExplorerSubmission[]
  MentoringVlogSubmission       MentoringVlogSubmission[]
  MentoringReflection           MentoringReflection[]

  @@index([isAdmin], map: "users_is_admin_idx")
  @@map("users")
}

model Connection {
  id         Int      @id @default(autoincrement())
  from       User     @relation(fields: [fromId], references: [id], name: "from")
  fromId     Int      @map("from_id")
  to         User     @relation(fields: [toId], references: [id], name: "to")
  toId       Int      @map("to_id")
  status     String
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@unique([fromId, toId])
  @@index([toId], map: "connections_to_id_idx")
  @@map("connections")
}

model ConnectionRequest {
  id         Int      @id @default(autoincrement())
  from       User     @relation(fields: [fromId], references: [id], name: "from")
  fromId     Int      @map("from_id")
  to         User     @relation(fields: [toId], references: [id], name: "to")
  toId       Int      @map("to_id")
  status     String
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@unique([fromId, toId])
  @@index([toId], map: "connection_requests_to_id_idx")
  @@map("connection_requests")
}

model NetworkingSubmission {
  id        Int                @id @default(autoincrement())
  user      User               @relation("NetworkingSubmissionOwner", fields: [userId], references: [id], onDelete: Cascade)
  userId    Int                @map("user_id")
  friend    User               @relation("NetworkingSubmissionFriend", fields: [friendId], references: [id], onDelete: Cascade)
  friendId  Int                @map("friend_id")
  photoUrl  String             @map("photo_url")
  answers   NetworkingAnswer[]
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @default(now()) @updatedAt @map("updated_at")

  @@unique([userId, friendId])
  @@index([friendId], map: "networking_submissions_friend_id_idx")
  @@map("networking_submissions")
}

model NetworkingQuestion {
  id           Int                       @id @default(autoincrement())
  questionType NetworkingQuestionType    @default(PEER) @map("question_type")
  code         String
  prompt       String
  position     Int
  isCustom     Boolean                   @default(false) @map("is_custom")
  isActive     Boolean                   @default(true) @map("is_active")
  answers      NetworkingAnswer[]

  @@unique([questionType, code])
  @@unique([questionType, position])
  @@map("networking_questions")
}

model NetworkingAnswer {
  submission     NetworkingSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  submissionId   Int                  @map("submission_id")
  question       NetworkingQuestion   @relation(fields: [questionId], references: [id], onDelete: Restrict)
  questionId     Int                  @map("question_id")
  answer         String
  customQuestion String?              @map("custom_question")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @default(now()) @updatedAt @map("updated_at")

  @@id([submissionId, questionId])
  @@index([questionId], map: "networking_answers_question_id_idx")
  @@map("networking_answers")
}

model Quotes {
  id         Int      @id @default(autoincrement())
  quote      String
  user       User     @relation(fields: [userId], references: [id])
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  userId     Int

  @@map("quotes")
}

model FirstFossibSessionSubmission {
  id          Int     @id @default(autoincrement())
  user        User    @relation(fields: [userId], references: [id])
  file_url    String? @map("file_url")
  photo_url   String? @map("photo_url")
  description String?
  userId      Int     @unique
}

model SecondFossibSessionSubmission {
  id          Int     @id @default(autoincrement())
  user        User    @relation(fields: [userId], references: [id])
  file_url    String? @map("file_url")
  photo_url   String? @map("photo_url")
  description String?
  userId      Int     @unique
}

model InsightHuntingSubmission {
  id       Int    @id @default(autoincrement())
  user     User   @relation(fields: [userId], references: [id])
  file_url String @map("file_url")
  userId   Int    @unique
}

model ExplorerSubmission {
  id           Int     @id @default(autoincrement())
  user         User    @relation(fields: [userId], references: [id])
  activityName String? @map("activity_name")
  img_url      String  @map("img_url")
  userId       Int     @unique
}

model FossibSubmission {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int      @unique @map("user_id")
  fileUrl   String   @map("file_url")
  photoUrl  String   @map("photo_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("fossib_submissions")
}

model MentoringSubmission {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int      @unique @map("user_id")
  gdriveUrl String   @map("gdrive_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("mentoring_submissions")
}

model MentoringReflection {
  id          Int     @id @default(autoincrement())
  user        User    @relation(fields: [userId], references: [id])
  file_url    String? @map("file_url")
  description String?
  userId      Int     @unique
}

model MentoringVlogSubmission {
  id          Int     @id @default(autoincrement())
  user        User    @relation(fields: [userId], references: [id])
  file_url    String  @map("file_url")
  description String?
  userId      Int     @unique
}

model TimelineEvent {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  startsAt    DateTime @map("starts_at")
  location    String?
  meetingUrl  String?  @map("meeting_url")
  position    Int      @default(0)
  isPublished Boolean  @default(true) @map("is_published")

  @@map("timeline_events")
}

model Faq {
  id          Int     @id @default(autoincrement())
  question    String
  answer      String
  position    Int     @default(0)
  isPublished Boolean @default(true) @map("is_published")

  @@map("faqs")
}

model Sponsor {
  id          Int     @id @default(autoincrement())
  name        String
  imgUrl      String  @map("img_url")
  websiteUrl  String? @map("website_url")
  position    Int     @default(0)
  isPublished Boolean @default(true) @map("is_published")

  @@map("sponsors")
}

model MaterialCategory {
  id        Int        @id @default(autoincrement())
  name      String
  position  Int        @default(0)
  materials Material[]

  @@map("material_categories")
}

model Material {
  id           Int              @id @default(autoincrement())
  title        String
  description  String?
  videoUrl     String           @map("video_url")
  thumbnailUrl String?          @map("thumbnail_url")
  position     Int              @default(0)
  isPublished  Boolean          @default(true) @map("is_published")
  category     MaterialCategory @relation(fields: [categoryId], references: [id])
  categoryId   Int              @map("category_id")

  @@map("materials")
}
